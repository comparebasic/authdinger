{
    "dirs":{
        "page": "example/page",
        "inc": "example/inc",
        "static": "example/static",
        "user-data": "example/user-data",
        "auth-data": "example/auth-data",
        "sessions": "example/sessions",
        "emails": "example/emails"
    },
    "routes": {
        "/": [
            "get", "content=welcome.html@page"],
        "/auth/login": [
            ["get", "map=action/path@req", "map=redir@query", "content=login-form.format@page"],
            ["post", "map=email,data-send-email?,password?@form",
                ["data=on@send-auth-email", "auth_email", "session_start", "redir=redir@data"],
                ["pw_auth", "session_start", "map=redir@query", "redir=redir@data"] 
            ],
            ["map=action/path@req", "map=redir@query", "content=login-form.format@page"]
        ],
        "/auth/token-login": [
            ["get", "token_consume", "session_start", "redir=data.redir"],
            ["get", "content=token.format@page"]
        ],
        "/auth/register": [
            ["get", "map=action/path@req", "map=redir@query", "content=register.format@page"],
            ["post", "map=action/path@req", "map=redir@query", "map=email,fullname,data-send-email?,password?@form",
                ["data=on@send-auth-email", "get_token", "map=brand,url@config", "email=auth-token-email",
                    "content=email-sent.format@page"],
                ["register", "pw_set", "redir=data.redir"] 
            ],
            ["content=register.format@page"]
        ],
        "/auth/dashboard": [
            ["get", "session_open", "map=email,fullname@session", "content=dashboard.format@page"],
            ["redir=/auth/login"]
        ],
        "/static/styles.css": ["content=styles.css@static"],
        "/static/form.js": ["content=form.js@static"],
        "/not-found": ["content=not-found.html@page"],
        "/error": ["content=error.format@page"]
    },
    "templates": {
        "page": ["content=header.html@inc", true, "content=footer.html@inc"]
    },
    "fields": {
        "session": {
            "email-token": "unquote=email",
            "start-time": false,
            "session-token": true,
            "fullname": true
        },
        "user": {
            "fullname": true,
            "salt": false,
            "email-token": "unquote=email"
        },
        "auth": {
            "email-token": true,
            "password": false
        }
    },
    "port": 3000,
    "auth-socket": "example/auth.sock",
    "sasl-socket": "example/sasl.sock",
    "system-email": "noreply@cb-local",
    "brand": "Authdinger",
    "url": "http://localhost:3000/",
    "smtp": "localhost"
}
